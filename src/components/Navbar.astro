---
import Logo from './Logo.astro';
import ThemeToggle from './ThemeToggle.astro';
import { navLinks } from '../data/site';
---

<header class="fixed inset-x-0 top-0 z-40">
    <div class="container-site mt-3 sm:mt-4">
        <div
            class="chrome-nav-shell flex h-14 items-center justify-between gap-4 rounded-full border border-[var(--border)] bg-[color-mix(in_srgb,var(--bg)_72%,transparent)] px-4 shadow-[var(--shadow-sm)] backdrop-blur-2xl sm:h-16 sm:px-6"
        >
            <a href="#hero" class="block size-8 shrink-0 text-[var(--fg)] sm:size-9" aria-label="Ana sayfa">
                <Logo />
            </a>

            <nav class="hidden items-center gap-1 md:flex" aria-label="Ana menü">
                {
                    navLinks.map((link) => (
                        <a
                            href={link.href}
                            data-nav-link={link.href}
                            class="nav-link rounded-full px-4 py-2 text-sm font-bold text-[var(--fg-muted)] transition hover:text-[var(--fg)]"
                        >
                            {link.label}
                        </a>
                    ))
                }
                <a href="#contact" class="btn btn-primary ml-2 !py-2 text-sm">Teklif Al</a>
            </nav>

            <div class="flex items-center gap-2">
                <ThemeToggle />
            </div>
        </div>
    </div>
</header>

<style>
    .chrome-nav-shell {
        position: relative;
        overflow: clip;
    }

    .chrome-nav-shell::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--accent) 16%, transparent), transparent);
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

    .chrome-nav-shell[data-lab='true']::before {
        opacity: 1;
    }

    .nav-link[data-active='true'] {
        color: var(--fg);
        background: color-mix(in srgb, var(--accent) 18%, transparent);
    }
</style>
