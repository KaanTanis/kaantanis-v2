---
import { dockLinks } from '../data/site';

const icons: Record<string, string> = {
    hero: 'M2.25 12 12 2.25 21.75 12M4.5 9.75v10.5a.75.75 0 0 0 .75.75H9.75V15h4.5v6h4.5a.75.75 0 0 0 .75-.75V9.75',
    about: 'M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.5 20.25a7.5 7.5 0 0 1 15 0v.75H4.5v-.75Z',
    process: 'M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5',
    contact: 'M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75',
};
---

<nav
    id="mobile-dock"
    class="fixed inset-x-0 bottom-3 z-40 mx-auto flex max-w-[22rem] items-center justify-between gap-1 rounded-full border border-[var(--border)] bg-[var(--dock-bg)] p-1.5 shadow-[var(--shadow-lg)] backdrop-blur-2xl md:hidden"
    aria-label="Mobil navigasyon"
    style="padding-bottom: max(0.375rem, env(safe-area-inset-bottom));"
>
    {
        dockLinks.map((link) => (
            <a
                href={link.href}
                data-dock-link={link.id}
                class="dock-item group relative flex flex-1 flex-col items-center justify-center gap-0.5 rounded-full px-2 py-2 text-[10px] font-bold text-[var(--fg-muted)] transition"
                aria-label={link.label}
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="size-5"
                    aria-hidden="true"
                >
                    <path stroke-linecap="round" stroke-linejoin="round" d={icons[link.id]} />
                </svg>
                <span class="leading-none">{link.label}</span>
            </a>
        ))
    }
</nav>

<style>
    #mobile-dock {
        overflow: clip;
    }

    #mobile-dock::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: radial-gradient(circle at top, color-mix(in srgb, var(--accent) 20%, transparent), transparent 60%);
        opacity: 0.6;
        pointer-events: none;
    }

    .dock-item[data-active='true'] {
        background: color-mix(in srgb, var(--accent) 90%, transparent);
        color: var(--accent-fg);
        transform: translateY(-1px);
    }
    .dock-item:active {
        transform: scale(0.92);
    }
</style>
