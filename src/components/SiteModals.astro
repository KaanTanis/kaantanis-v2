---
import { privacyPolicyHtml, cookieNoticeHtml } from '../data/site';
---

<dialog id="privacy-modal" class="site-modal lab-modal">
    <div class="site-modal-box prose-modal">
        <h2 class="text-xl font-bold">Gizlilik Politikası</h2>
        <div class="mt-4 space-y-3 text-sm text-[var(--fg-muted)]" set:html={privacyPolicyHtml} />
        <form method="dialog" class="mt-8">
            <button type="submit" class="btn btn-primary">Kapat</button>
        </form>
    </div>
</dialog>

<dialog id="surprise-modal" class="site-modal lab-modal surprise-modal">
    <div class="site-modal-box surprise-modal-box">
        <p class="surprise-emoji" aria-hidden="true">⚡🫶🌆</p>
        <h2 class="surprise-title">Tekrar hoş geldin!</h2>
        <p class="surprise-text">
            24 saat içinde ikinci kez uğradığın için sana özel <strong>cyberpunk</strong> modunu açtım 💜✨
            Umarım küçük sürpriz hoşuna gider — kaydırmaya devam et, seni bekliyorum 🚀
        </p>
        <form method="dialog" class="mt-6">
            <button type="submit" class="btn btn-primary surprise-btn">Harika, devam! 🫶</button>
        </form>
    </div>
</dialog>

<dialog id="cookie-modal" class="site-modal lab-modal">
    <div class="site-modal-box prose-modal">
        <h2 class="text-xl font-bold">Çerezler</h2>
        <div class="mt-4 space-y-3 text-sm text-[var(--fg-muted)]" set:html={cookieNoticeHtml} />
        <form method="dialog" class="mt-8">
            <button type="submit" class="btn btn-primary">Kapat</button>
        </form>
    </div>
</dialog>

<div
    id="cookie-consent"
    class="cookie-banner hidden"
    role="dialog"
    aria-label="Çerez bildirimi"
>
    <div class="cookie-banner-inner">
        <p class="cookie-banner-text">
            Çerezler kullanıyoruz.
            <button type="button" class="cookie-banner-link" data-open-cookie>Detay</button>
        </p>
        <button type="button" id="accept-cookie" class="cookie-banner-accept">Tamam</button>
    </div>
</div>

<style>
    .site-modal {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        margin: 0;
        max-width: min(42rem, calc(100vw - 2rem));
        width: calc(100% - 2rem);
        border: none;
        border-radius: var(--radius-lg);
        padding: 0;
        background: transparent;
        overflow: visible;
    }
    .site-modal[open] {
        display: block;
    }
    .site-modal::backdrop {
        background: rgb(0 0 0 / 0.55);
        backdrop-filter: blur(4px);
    }

    .lab-modal::backdrop {
        background: rgb(0 0 0 / 0.62);
        backdrop-filter: blur(6px);
    }

    .site-modal-box {
        background: color-mix(in srgb, var(--bg) 86%, transparent);
        color: var(--fg);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 2rem;
        box-shadow: var(--shadow-md);
        backdrop-filter: blur(14px);
    }

    .surprise-modal {
        width: min(26rem, calc(100vw - 2rem));
        max-width: min(26rem, calc(100vw - 2rem));
    }
    .surprise-modal-box {
        text-align: center;
        width: 100%;
        margin-inline: auto;
        border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
        box-shadow: var(--shadow-lg), 0 0 40px color-mix(in srgb, var(--accent) 25%, transparent);
    }
    .surprise-emoji {
        font-size: 2.5rem;
        line-height: 1;
        margin: 0 0 0.75rem;
        letter-spacing: 0.2em;
    }
    .surprise-title {
        font-size: 1.5rem;
        font-weight: 800;
        margin: 0 0 0.75rem;
        letter-spacing: -0.02em;
    }
    .surprise-text {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.65;
        color: var(--fg-muted);
    }
    .surprise-text strong {
        color: var(--accent);
    }
    .surprise-btn {
        width: 100%;
        justify-content: center;
    }

    /* Kompakt çerez bildirimi */
    .cookie-banner {
        position: fixed;
        z-index: 50;
        right: max(0.65rem, env(safe-area-inset-right, 0px));
        bottom: calc(5.25rem + env(safe-area-inset-bottom, 0px));
        left: auto;
        max-width: min(20rem, calc(100vw - 1.25rem));
        padding: 0.5rem 0.55rem 0.5rem 0.7rem;
        border: 1px solid var(--border);
        border-radius: 9999px;
        background: color-mix(in srgb, var(--surface) 92%, transparent);
        box-shadow: var(--shadow-md);
        backdrop-filter: blur(14px);
    }

    @media (min-width: 640px) {
        .cookie-banner {
            bottom: 1.25rem;
            max-width: 22rem;
            padding: 0.6rem 0.65rem 0.6rem 0.85rem;
            border-radius: 1rem;
        }
    }

    .cookie-banner-inner {
        display: flex;
        align-items: center;
        gap: 0.55rem;
    }

    .cookie-banner-text {
        margin: 0;
        font-size: 0.68rem;
        line-height: 1.35;
        font-weight: 700;
        color: var(--fg-muted);
        white-space: nowrap;
    }

    @media (min-width: 640px) {
        .cookie-banner-text {
            font-size: 0.75rem;
            white-space: normal;
        }
    }

    .cookie-banner-link {
        margin-left: 0.15rem;
        padding: 0;
        border: none;
        background: none;
        font: inherit;
        font-weight: 800;
        color: var(--fg);
        text-decoration: underline;
        text-underline-offset: 2px;
        cursor: pointer;
    }

    .cookie-banner-accept {
        flex-shrink: 0;
        padding: 0.35rem 0.7rem;
        border: none;
        border-radius: 9999px;
        background: var(--accent);
        color: var(--accent-fg);
        font-size: 0.68rem;
        font-weight: 800;
        line-height: 1;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .cookie-banner-accept:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-sm);
    }

    @media (min-width: 640px) {
        .cookie-banner-accept {
            padding: 0.4rem 0.85rem;
            font-size: 0.72rem;
        }
    }
</style>

<script>
    type VisitState = {
        visits: number[];
        surpriseShown: boolean;
        userPickedTheme: boolean;
        pendingSurprise: boolean;
    };

    function readVisitState(): VisitState | null {
        try {
            const raw = localStorage.getItem('kaan-visit-state');
            if (!raw) return null;
            const parsed = JSON.parse(raw) as VisitState;
            if (!parsed || !Array.isArray(parsed.visits)) return null;
            return parsed;
        } catch {
            return null;
        }
    }

    function initSurpriseModal() {
        const state = readVisitState();
        if (!state?.pendingSurprise) return;

        const modal = document.getElementById('surprise-modal') as HTMLDialogElement | null;
        if (!modal) return;

        state.pendingSurprise = false;
        state.surpriseShown = true;
        try {
            localStorage.setItem('kaan-visit-state', JSON.stringify(state));
            localStorage.removeItem('kaan-surprise-shown');
            localStorage.removeItem('kaan-show-surprise');
        } catch {}

        requestAnimationFrame(() => {
            if (!modal.open) modal.showModal();
        });
    }

    function initModals() {
        initSurpriseModal();

        document.querySelectorAll('[data-open-privacy]').forEach((el) => {
            el.addEventListener('click', () => document.getElementById('privacy-modal')?.showModal());
        });
        document.querySelectorAll('[data-open-cookie]').forEach((el) => {
            el.addEventListener('click', () => document.getElementById('cookie-modal')?.showModal());
        });

        const banner = document.getElementById('cookie-consent');
        const accept = document.getElementById('accept-cookie');
        if (banner && !localStorage.getItem('cookie-consent')) {
            banner.classList.remove('hidden');
        }
        accept?.addEventListener('click', () => {
            localStorage.setItem('cookie-consent', '1');
            banner?.classList.add('hidden');
            import('../scripts/analytics.ts').then((m) => m.loadAnalytics());
        });
    }

    initModals();
    document.addEventListener('astro:page-load', initModals);
</script>
