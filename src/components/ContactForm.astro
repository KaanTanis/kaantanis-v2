---
import { contact } from '../data/site';
---

<section id="contact" class="scroll-mt-20 py-24 md:py-32">
    <div class="container-site max-w-5xl">
        <div class="contact-shell text-center">
            <span class="eyebrow reveal" data-reveal>{contact.eyebrow}</span>
            <h2
                id="contactTitle"
                class="display-section reveal mt-4 text-4xl sm:text-5xl md:text-6xl lg:text-7xl"
                data-reveal
                data-reveal-delay="0.05"
                set:html={contact.heading}
            />
            <p class="reveal mt-5 text-base font-medium text-[var(--fg-muted)] sm:text-lg md:text-xl" data-reveal data-reveal-delay="0.1">
                {contact.subheading}
            </p>
        </div>

        <form id="contact-form" class="contact-form mt-12 space-y-6 reveal contact-card" data-reveal data-reveal-delay="0.15" novalidate>
            <div class="grid gap-4 sm:grid-cols-2 sm:gap-6 lg:grid-cols-12">
                <div class="lg:col-span-6">
                    <label class="sr-only" for="name">Adınız</label>
                    <input class="input" type="text" id="name" name="name" placeholder="Adınız" required autocomplete="name" />
                </div>
                <div class="lg:col-span-6">
                    <label class="sr-only" for="phone">Telefon</label>
                    <input class="input" type="tel" id="phone" name="phone" placeholder="Telefon Numaranız" required autocomplete="tel" />
                </div>
            </div>
            <div class="lg:col-span-12">
                <label class="sr-only" for="email">E-posta</label>
                <input class="input" type="email" id="email" name="email" placeholder="E-posta Adresiniz" required autocomplete="email" />
            </div>

            <fieldset class="lg:col-span-12">
                <legend class="mb-3 text-sm font-bold text-[var(--fg)]">Hizmetler</legend>
                <div class="flex flex-wrap gap-2">
                    {
                        contact.services.map((s) => (
                            <label class="chip relative">
                                <input type="checkbox" name="services" value={s.id} />
                                {s.label}
                            </label>
                        ))
                    }
                </div>
            </fieldset>

            <fieldset class="lg:col-span-12">
                <legend class="mb-3 text-sm font-bold text-[var(--fg)]">Bütçe</legend>
                <div class="flex flex-wrap gap-2">
                    {
                        contact.budgets.map((b, i) => (
                            <label class="chip relative">
                                <input type="radio" name="budget" value={b.value} checked={i === 1} required />
                                {b.label}
                            </label>
                        ))
                    }
                </div>
            </fieldset>

            <div class="lg:col-span-12">
                <label class="sr-only" for="message">Mesaj</label>
                <textarea class="input min-h-[10rem] resize-y" id="message" name="message" rows="6" placeholder="Proje Detayları" required></textarea>
            </div>

            <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between lg:col-span-12">
                <label class="flex items-start gap-3 text-xs font-semibold text-[var(--fg-muted)]">
                    <input type="checkbox" id="gdpr" class="mt-0.5 size-4 rounded border-[var(--border)]" required />
                    <span>
                        <button type="button" class="font-extrabold text-[var(--fg)] underline underline-offset-2" data-open-privacy>
                            Gizlilik Politikasını
                        </button>
                        kabul ediyorum
                    </span>
                </label>
                <button type="submit" class="btn btn-primary w-full sm:w-48" id="contact-submit">
                    Gönder
                </button>
            </div>

            <p id="contact-feedback" class="hidden text-center text-sm font-semibold lg:col-span-12" role="status" aria-live="polite"></p>
        </form>
    </div>
</section>

<style>
    .contact-shell {
        position: relative;
        isolation: isolate;
    }

    .contact-shell::before,
    .contact-shell::after {
        content: '';
        position: absolute;
        border-radius: 9999px;
        filter: blur(64px);
        opacity: 0.25;
        z-index: -1;
        pointer-events: none;
    }

    .contact-shell::before {
        width: 14rem;
        height: 14rem;
        left: 4%;
        top: 0;
        background: color-mix(in srgb, var(--accent) 50%, transparent);
    }

    .contact-shell::after {
        width: 18rem;
        height: 18rem;
        right: 2%;
        top: 20%;
        background: color-mix(in srgb, var(--fg) 30%, transparent);
    }

    .contact-card {
        border: 1px solid var(--border);
        border-radius: 1.5rem;
        background: color-mix(in srgb, var(--surface) 85%, transparent);
        box-shadow: var(--shadow-md);
        backdrop-filter: blur(16px);
        padding: 1.25rem;
    }

    @media (min-width: 640px) {
        .contact-card {
            padding: 1.75rem;
        }
    }

    @media (min-width: 1024px) {
        .contact-card {
            padding: 2rem;
        }
    }
</style>

<script>
    function initContactForm() {
        const form = document.getElementById('contact-form') as HTMLFormElement | null;
        if (!form || form.dataset.bound) return;
        form.dataset.bound = '1';

        const feedback = document.getElementById('contact-feedback');
        const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!feedback || !submitBtn) return;

            const services = [...form.querySelectorAll<HTMLInputElement>('input[name="services"]:checked')].map(
                (el) => el.value,
            );
            const budgetEl = form.querySelector<HTMLInputElement>('input[name="budget"]:checked');

            const payload = {
                name: (form.elements.namedItem('name') as HTMLInputElement).value.trim(),
                email: (form.elements.namedItem('email') as HTMLInputElement).value.trim(),
                phone: (form.elements.namedItem('phone') as HTMLInputElement).value.trim(),
                services,
                budget: Number(budgetEl?.value ?? 25),
                message: (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim(),
            };

            feedback.classList.add('hidden');
            submitBtn.disabled = true;
            submitBtn.textContent = 'Gönderiliyor…';

            try {
                const res = await fetch('/api/contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                    body: JSON.stringify(payload),
                });
                const data = (await res.json()) as { ok: boolean; message?: string };

                feedback.textContent = data.message ?? (data.ok ? 'Mesajınız gönderildi.' : 'Bir hata oluştu.');
                feedback.className = `text-center text-sm font-semibold ${data.ok ? 'text-emerald-500' : 'text-red-500'}`;
                feedback.classList.remove('hidden');

                if (data.ok) form.reset();
            } catch {
                feedback.textContent = 'Bağlantı hatası. Lütfen tekrar deneyin.';
                feedback.className = 'text-center text-sm font-semibold text-red-500';
                feedback.classList.remove('hidden');
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Gönder';
            }
        });
    }

    initContactForm();
    document.addEventListener('astro:page-load', initContactForm);
</script>
