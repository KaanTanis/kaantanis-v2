---
import { contact } from '../data/site';
---

<section id="contact" class="chat-section scroll-mt-20 py-20 md:py-28 relative overflow-hidden">
    <div class="chat-ambient chat-ambient-a" aria-hidden="true"></div>
    <div class="chat-ambient chat-ambient-b" aria-hidden="true"></div>

    <div class="container-site relative z-10">
        <div class="chat-grid">
            <!-- Side prelude -->
            <aside class="chat-prelude">
                <span class="eyebrow reveal" data-reveal>{contact.eyebrow}</span>
                <h2 id="contactTitle" class="display-section reveal mt-4 text-4xl sm:text-5xl md:text-6xl lg:text-7xl" data-reveal data-reveal-delay="0.05" set:html={contact.heading} />
                <p class="reveal mt-5 text-base font-medium text-[var(--fg-muted)] sm:text-lg" data-reveal data-reveal-delay="0.1">
                    {contact.subheading}
                </p>

                <div class="chat-stats reveal" data-reveal data-reveal-delay="0.15">
                    <div class="chat-stat">
                        <p class="chat-stat-value">24<span>h</span></p>
                        <p class="chat-stat-label">İlk dönüş</p>
                    </div>
                    <div class="chat-stat">
                        <p class="chat-stat-value">100<span>%</span></p>
                        <p class="chat-stat-label">Yanıt oranı</p>
                    </div>
                    <div class="chat-stat">
                        <p class="chat-stat-value">5<span>★</span></p>
                        <p class="chat-stat-label">Müşteri puanı</p>
                    </div>
                </div>
            </aside>

            <!-- Chat panel -->
            <form id="contact-form" class="chat-panel reveal" data-reveal data-reveal-delay="0.2" novalidate>
                <header class="chat-header">
                    <div class="chat-avatar" aria-hidden="true">KT</div>
                    <div class="chat-meta">
                        <p class="chat-name">Kaan Tanış</p>
                        <p class="chat-status"><span class="chat-online"></span> aktif · sohbeti başlat</p>
                    </div>
                    <span class="chat-secure" aria-hidden="true">e2e</span>
                </header>

                <div class="chat-stream" data-chat-stream>
                    <div class="bubble bubble-from" data-bubble>
                        <p>Selam <span aria-hidden="true">👋</span> Projeni konuşmak için sabırsızlanıyorum.</p>
                        <span class="bubble-time">şimdi</span>
                    </div>
                    <div class="bubble bubble-from" data-bubble>
                        <p>Birkaç hızlı soru sorayım, alttaki balonlardan yanıtla.</p>
                        <span class="bubble-time">şimdi</span>
                    </div>

                    <div class="chat-q" data-bubble><span class="chat-q-step">1 / 5</span> Sana nasıl hitap edeyim?</div>
                    <label class="bubble bubble-input" data-bubble>
                        <input class="bubble-field" type="text" name="name" placeholder="Adınız" required autocomplete="name" />
                    </label>

                    <div class="chat-q" data-bubble><span class="chat-q-step">2 / 5</span> Sana nasıl ulaşayım?</div>
                    <div class="bubble-row" data-bubble>
                        <label class="bubble bubble-input">
                            <input class="bubble-field" type="email" name="email" placeholder="E-posta" required autocomplete="email" />
                        </label>
                        <label class="bubble bubble-input">
                            <input class="bubble-field" type="tel" name="phone" placeholder="Telefon" required autocomplete="tel" />
                        </label>
                    </div>

                    <div class="chat-q" data-bubble><span class="chat-q-step">3 / 5</span> Hangi konuda destek arıyorsun?</div>
                    <div class="bubble-cloud" data-bubble>
                        {contact.services.map((s) => (
                            <label class="chip">
                                <input type="checkbox" name="services" value={s.id} />
                                {s.label}
                            </label>
                        ))}
                    </div>

                    <div class="chat-q" data-bubble><span class="chat-q-step">4 / 5</span> Bütçe aralığın?</div>
                    <div class="bubble-cloud" data-bubble>
                        {contact.budgets.map((b, i) => (
                            <label class="chip">
                                <input type="radio" name="budget" value={b.value} checked={i === 1} required />
                                {b.label}
                            </label>
                        ))}
                    </div>

                    <div class="chat-q" data-bubble><span class="chat-q-step">5 / 5</span> Projeni biraz anlat</div>
                    <label class="bubble bubble-input bubble-textarea" data-bubble>
                        <textarea class="bubble-field" name="message" rows="4" placeholder="Projenizden bahsedin..." required></textarea>
                    </label>

                    <div class="bubble bubble-from" data-bubble>
                        <p>Hazır olduğunda gönder — 24 saat içinde dönerim.</p>
                        <span class="bubble-time">şimdi</span>
                    </div>
                </div>

                <footer class="chat-composer">
                    <label class="chat-gdpr">
                        <input type="checkbox" id="gdpr" required />
                        <span>
                            <button type="button" class="chat-gdpr-link" data-open-privacy>Gizlilik Politikası</button>'nı kabul ediyorum
                        </span>
                    </label>
                    <button type="submit" class="chat-send" id="contact-submit" aria-label="Mesajı gönder">
                        <span>Gönder</span>
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <line x1="22" y1="2" x2="11" y2="13" />
                            <polygon points="22 2 15 22 11 13 2 9 22 2" />
                        </svg>
                    </button>
                </footer>

                <p id="contact-feedback" class="chat-feedback hidden" role="status" aria-live="polite"></p>
            </form>
        </div>
    </div>
</section>

<style>
    .chat-section { isolation: isolate; }
    .chat-ambient {
        position: absolute;
        border-radius: 9999px;
        filter: blur(110px);
        pointer-events: none;
        opacity: 0.2;
    }
    .chat-ambient-a {
        width: 26rem; height: 26rem;
        top: 4rem; left: -8rem;
        background: color-mix(in srgb, var(--accent) 55%, transparent);
    }
    .chat-ambient-b {
        width: 30rem; height: 30rem;
        bottom: -4rem; right: -10rem;
        background: color-mix(in srgb, var(--fg) 25%, transparent);
    }

    .chat-grid {
        display: grid;
        gap: 2rem;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
        align-items: start;
    }
    @media (max-width: 980px) {
        .chat-grid { grid-template-columns: minmax(0, 1fr); }
    }

    .chat-prelude {
        position: sticky;
        top: 6.5rem;
    }
    @media (max-width: 980px) { .chat-prelude { position: static; } }

    .chat-stats {
        margin-top: 2rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
    }
    .chat-stat {
        padding: 1rem;
        border: 1px solid var(--border);
        border-radius: 1rem;
        background: color-mix(in srgb, var(--surface) 85%, transparent);
        backdrop-filter: blur(12px);
    }
    .chat-stat-value {
        margin: 0 0 0.25rem;
        font-size: 1.6rem;
        font-weight: 900;
        letter-spacing: -0.02em;
        color: var(--fg-strong);
        font-variant-numeric: tabular-nums;
    }
    .chat-stat-value span {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--accent);
        margin-left: 0.15rem;
    }
    .chat-stat-label {
        margin: 0;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--fg-subtle);
    }

    /* Chat panel */
    .chat-panel {
        border: 1px solid var(--border);
        border-radius: 1.5rem;
        background: color-mix(in srgb, var(--surface) 86%, transparent);
        box-shadow: var(--shadow-lg);
        backdrop-filter: blur(20px);
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    .chat-header {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 0.9rem 1.1rem;
        border-bottom: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
        background: color-mix(in srgb, var(--bg-muted) 60%, transparent);
    }
    .chat-avatar {
        width: 2.4rem;
        height: 2.4rem;
        border-radius: 9999px;
        background: var(--accent);
        color: var(--accent-fg);
        display: grid;
        place-items: center;
        font-weight: 900;
        font-size: 0.85rem;
        letter-spacing: 0.04em;
        box-shadow: var(--shadow-sm);
    }
    .chat-meta { flex: 1; }
    .chat-name {
        margin: 0;
        font-size: 0.95rem;
        font-weight: 800;
        color: var(--fg-strong);
    }
    .chat-status {
        margin: 0;
        font-size: 0.72rem;
        color: var(--fg-muted);
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .chat-online {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 9999px;
        background: #28c840;
        box-shadow: 0 0 0 3px color-mix(in srgb, #28c840 25%, transparent);
        display: inline-block;
    }
    .chat-secure {
        padding: 0.3rem 0.55rem;
        border-radius: 0.5rem;
        font-size: 0.62rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--fg-muted);
        border: 1px solid var(--border);
        background: var(--bg-muted);
    }

    /* Stream */
    .chat-stream {
        padding: 1.1rem;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        max-height: 36rem;
        overflow-y: auto;
        background:
            radial-gradient(circle at 10% 10%, color-mix(in srgb, var(--accent) 6%, transparent), transparent 60%),
            radial-gradient(circle at 90% 90%, color-mix(in srgb, var(--fg) 6%, transparent), transparent 60%);
    }
    .chat-stream::-webkit-scrollbar { width: 4px; }
    .chat-stream::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 9999px; }

    .bubble {
        position: relative;
        max-width: 85%;
        padding: 0.75rem 0.95rem;
        border-radius: 1.1rem;
        font-size: 0.93rem;
        line-height: 1.5;
        color: var(--fg);
    }
    .bubble p { margin: 0; }
    .bubble + .bubble { margin-top: 0; }

    .bubble-from {
        align-self: flex-start;
        background: color-mix(in srgb, var(--bg-muted) 80%, transparent);
        border: 1px solid var(--border);
        border-bottom-left-radius: 0.35rem;
    }
    .bubble-time {
        display: block;
        margin-top: 0.3rem;
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--fg-subtle);
    }

    .chat-q {
        align-self: flex-start;
        padding: 0.45rem 0.75rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--fg-muted);
        background: transparent;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .chat-q-step {
        padding: 0.18rem 0.5rem;
        border-radius: 9999px;
        background: color-mix(in srgb, var(--accent) 15%, transparent);
        color: var(--accent);
        font-size: 0.62rem;
        letter-spacing: 0.12em;
    }

    .bubble-input {
        align-self: flex-end;
        background: var(--accent);
        color: var(--accent-fg);
        border-bottom-right-radius: 0.35rem;
        padding: 0.4rem 0.6rem;
        max-width: 85%;
        cursor: text;
    }
    .bubble-input:focus-within {
        outline: 2px solid color-mix(in srgb, var(--accent) 50%, transparent);
        outline-offset: 2px;
    }
    .bubble-field {
        width: 100%;
        border: none;
        outline: none;
        background: transparent;
        color: inherit;
        font: inherit;
        padding: 0.4rem 0.5rem;
    }
    .bubble-field::placeholder {
        color: color-mix(in srgb, var(--accent-fg) 60%, transparent);
        opacity: 0.85;
    }
    .bubble-textarea .bubble-field {
        resize: vertical;
        min-height: 4rem;
    }

    .bubble-row {
        align-self: flex-end;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.4rem;
        max-width: 90%;
        width: 100%;
    }
    .bubble-row .bubble-input {
        max-width: none;
    }

    .bubble-cloud {
        align-self: flex-end;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        max-width: 90%;
        justify-content: flex-end;
    }

    /* Composer */
    .chat-composer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.85rem;
        padding: 0.85rem 1.1rem;
        border-top: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
        background: color-mix(in srgb, var(--bg-muted) 50%, transparent);
        flex-wrap: wrap;
    }
    .chat-gdpr {
        display: flex;
        align-items: flex-start;
        gap: 0.55rem;
        font-size: 0.74rem;
        color: var(--fg-muted);
        font-weight: 600;
    }
    .chat-gdpr input[type='checkbox'] {
        width: 0.95rem;
        height: 0.95rem;
        accent-color: var(--accent);
    }
    .chat-gdpr-link {
        background: none;
        border: none;
        padding: 0;
        font: inherit;
        color: var(--fg);
        font-weight: 800;
        text-decoration: underline;
        text-underline-offset: 2px;
        cursor: pointer;
    }
    .chat-send {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.65rem 1.1rem;
        border-radius: 9999px;
        border: none;
        background: var(--accent);
        color: var(--accent-fg);
        font-size: 0.9rem;
        font-weight: 800;
        cursor: pointer;
        box-shadow: var(--shadow-sm);
        transition: transform 0.2s ease, box-shadow 0.25s ease;
    }
    .chat-send:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
    }
    .chat-send svg { transition: transform 0.3s ease; }
    .chat-send:hover svg { transform: translate(3px, -3px); }

    .chat-feedback {
        text-align: center;
        font-weight: 700;
        padding: 0.75rem 1rem;
        border-radius: 0.75rem;
        margin: 0.85rem;
        font-size: 0.85rem;
    }
    .chat-feedback.success {
        background: color-mix(in srgb, #10b981 12%, transparent);
        color: #10b981;
    }
    .chat-feedback.error {
        background: color-mix(in srgb, #ef4444 12%, transparent);
        color: #ef4444;
    }
    .hidden { display: none; }

    /* em underline scoped to title */
    #contactTitle em {
        font-style: normal;
        position: relative;
        white-space: nowrap;
    }
    #contactTitle em::after {
        content: '';
        position: absolute;
        left: 0; right: 0;
        bottom: 0.06em;
        height: 0.18em;
        background: var(--accent);
        opacity: 0.7;
        z-index: -1;
        border-radius: 9999px;
    }
</style>

<script>
    function initContactForm() {
        const form = document.getElementById('contact-form') as HTMLFormElement | null;
        if (!form || form.dataset.bound) return;
        form.dataset.bound = '1';

        const feedback = document.getElementById('contact-feedback');
        const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
        const submitLabel = submitBtn?.querySelector('span');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!feedback || !submitBtn || !submitLabel) return;

            const services = [...form.querySelectorAll<HTMLInputElement>('input[name="services"]:checked')].map(
                (el) => el.value,
            );
            const budgetEl = form.querySelector<HTMLInputElement>('input[name="budget"]:checked');

            const payload = {
                name: (form.elements.namedItem('name') as HTMLInputElement).value.trim(),
                email: (form.elements.namedItem('email') as HTMLInputElement).value.trim(),
                phone: (form.elements.namedItem('phone') as HTMLInputElement).value.trim(),
                services,
                budget: Number(budgetEl?.value ?? 25),
                message: (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim(),
            };

            feedback.classList.add('hidden');
            feedback.classList.remove('success', 'error');
            submitBtn.disabled = true;
            const originalLabel = submitLabel.textContent;
            submitLabel.textContent = 'Gönderiliyor…';

            try {
                const res = await fetch('/api/contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                    body: JSON.stringify(payload),
                });
                const data = (await res.json()) as { ok: boolean; message?: string };

                feedback.textContent = data.message ?? (data.ok ? 'Mesajınız gönderildi.' : 'Bir hata oluştu.');
                feedback.className = `chat-feedback ${data.ok ? 'success' : 'error'}`;
                feedback.classList.remove('hidden');

                if (data.ok) form.reset();
            } catch {
                feedback.textContent = 'Bağlantı hatası. Lütfen tekrar deneyin.';
                feedback.className = 'chat-feedback error';
                feedback.classList.remove('hidden');
            } finally {
                submitBtn.disabled = false;
                submitLabel.textContent = originalLabel ?? 'Gönder';
            }
        });
    }

    initContactForm();
    document.addEventListener('astro:page-load', initContactForm);
</script>
