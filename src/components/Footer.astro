---
import Logo from './Logo.astro';
import { site, hero } from '../data/site';
---

<footer class="border-t border-[var(--border)] py-10">
    <div class="container-site flex flex-col items-center justify-between gap-6 sm:flex-row">
        <div class="flex items-center gap-3">
            <a href="#hero" class="block size-9 text-[var(--fg)]" aria-label="Ana sayfa">
                <Logo />
            </a>
            <div>
                <p class="text-sm font-extrabold">{site.name}</p>
                <p class="text-xs text-[var(--fg-subtle)]">Designer & Developer</p>
            </div>
        </div>
        <div class="flex items-center gap-4 text-xs font-semibold text-[var(--fg-muted)]">
            <a href={`https://github.com/${hero.github}`} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--fg)]">GitHub</a>
            <span class="text-[var(--border-strong)]">·</span>
            <a href={`https://wa.me/${hero.whatsappLink}`} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--fg)]">WhatsApp</a>
            <span class="text-[var(--border-strong)]">·</span>
            <a href={`mailto:${hero.email}`} class="hover:text-[var(--fg)]">E-posta</a>
        </div>
        <p class="text-center text-xs text-[var(--fg-subtle)] sm:text-right">
            © {new Date().getFullYear()} · Designed & developed with <span aria-label="kalp">🫶</span>
        </p>
    </div>
</footer>
