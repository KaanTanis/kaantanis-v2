---
import { about, techStack } from '../data/site';
---

<section id="about" class="about-section scroll-mt-20 py-20 md:py-28">
    <div class="container-site about-layout">
        <header class="about-intro">
            <span class="eyebrow reveal" data-reveal>{about.eyebrow}</span>
            <h2
                class="display-section reveal mt-4 text-4xl sm:text-5xl md:text-6xl lg:text-[4.25rem]"
                data-reveal
                data-reveal-delay="0.05"
                set:html={about.title}
            />
        </header>

        <div class="about-prose rich reveal" data-reveal data-reveal-delay="0.1">
            {about.body.map((paragraph) => <p set:html={paragraph} />)}
        </div>

        <details class="tech-disclosure reveal" data-reveal data-reveal-delay="0.15">
            <summary class="tech-summary">
                <span class="tech-summary-text">
                    <span class="tech-summary-label">{techStack.label}</span>
                    <span class="tech-summary-title">{techStack.title}</span>
                </span>
                <span class="tech-preview" aria-hidden="true">
                    {techStack.preview.map((item) => (
                        <span class="tech-preview-tag">{item}</span>
                    ))}
                </span>
                <span class="tech-chevron" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
            </summary>

            <div class="tech-panel">
                <div class="tech-panel-inner">
                    {techStack.groups.map((group) => (
                        <div class="tech-group">
                            <p class="tech-group-label">{group.label}</p>
                            <ul class="tech-tags">
                                {group.items.map((item) => (
                                    <li class="tech-tag">{item}</li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>
            </div>
        </details>
    </div>
</section>

<style>
    .about-layout {
        display: grid;
        gap: 2rem;
        max-width: 42rem;
    }

    @media (min-width: 900px) {
        .about-layout {
            max-width: 46rem;
            gap: 2.25rem;
        }
    }

    .about-intro :global(em) {
        font-style: normal;
        position: relative;
        white-space: nowrap;
    }

    .about-intro :global(em)::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0.06em;
        height: 0.18em;
        background: var(--accent);
        opacity: 0.7;
        z-index: -1;
        border-radius: 9999px;
    }

    .about-prose {
        display: grid;
        gap: 1.25rem;
        font-size: 1rem;
        line-height: 1.8;
        color: var(--fg-muted);
    }

    @media (min-width: 640px) {
        .about-prose {
            font-size: 1.0625rem;
        }
    }

    .tech-disclosure {
        margin-top: 0.25rem;
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        background: var(--bg-muted);
        overflow: hidden;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .tech-disclosure[open] {
        border-color: var(--border-strong);
        box-shadow: var(--shadow-sm);
    }

    .tech-summary {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.875rem 1rem;
        cursor: pointer;
        list-style: none;
        user-select: none;
    }

    .tech-summary::-webkit-details-marker {
        display: none;
    }

    .tech-summary-text {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
        min-width: 0;
        flex-shrink: 0;
    }

    .tech-summary-label {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--fg-subtle);
    }

    .tech-summary-title {
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--fg);
        line-height: 1.3;
    }

    .tech-preview {
        display: none;
        align-items: center;
        gap: 0.375rem;
        flex: 1;
        min-width: 0;
        overflow: hidden;
    }

    @media (min-width: 480px) {
        .tech-preview {
            display: flex;
        }
    }

    .tech-disclosure[open] .tech-preview {
        display: none;
    }

    .tech-preview-tag {
        flex-shrink: 0;
        padding: 0.2rem 0.55rem;
        border-radius: var(--radius-full);
        border: 1px solid var(--border);
        background: var(--surface);
        font-size: 0.6875rem;
        font-weight: 600;
        color: var(--fg-muted);
        white-space: nowrap;
    }

    .tech-chevron {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-left: auto;
        color: var(--fg-subtle);
        transition: transform 0.25s ease, color 0.2s ease;
    }

    .tech-disclosure[open] .tech-chevron {
        transform: rotate(180deg);
        color: var(--fg);
    }

    .tech-summary:hover .tech-chevron {
        color: var(--fg);
    }

    .tech-summary:focus-visible {
        outline: 2px solid var(--ring);
        outline-offset: -2px;
        border-radius: var(--radius-lg);
    }

    .tech-panel {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.3s ease;
    }

    .tech-disclosure[open] .tech-panel {
        grid-template-rows: 1fr;
    }

    .tech-panel-inner {
        overflow: hidden;
        min-height: 0;
    }

    .tech-disclosure[open] .tech-panel-inner {
        padding: 0 1rem 1rem;
        display: grid;
        gap: 1rem;
        border-top: 1px solid var(--border);
        padding-top: 1rem;
        margin-top: 0;
    }

    .tech-group-label {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--fg-subtle);
        margin-bottom: 0.5rem;
    }

    .tech-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .tech-tag {
        padding: 0.35rem 0.75rem;
        border-radius: var(--radius-full);
        border: 1px solid var(--border);
        background: var(--surface);
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--fg-muted);
        line-height: 1.2;
    }
</style>
