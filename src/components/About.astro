---
import { about } from '../data/site';
---

<section id="about" class="about-section scroll-mt-20 py-20 md:py-28">
    <div class="container-site about-layout">
        <header class="about-intro">
            <span class="eyebrow reveal" data-reveal>{about.eyebrow}</span>
            <h2
                class="display-section reveal mt-4 text-4xl sm:text-5xl md:text-6xl lg:text-[4.25rem]"
                data-reveal
                data-reveal-delay="0.05"
                set:html={about.title}
            />
        </header>

        <div class="about-prose rich reveal" data-reveal data-reveal-delay="0.1">
            {about.body.map((paragraph) => <p set:html={paragraph} />)}
        </div>
    </div>
</section>

<style>
    .about-layout {
        display: grid;
        gap: 2rem;
        max-width: 42rem;
    }

    @media (min-width: 900px) {
        .about-layout {
            max-width: 46rem;
            gap: 2.25rem;
        }
    }

    .about-intro :global(em) {
        font-style: normal;
        position: relative;
        white-space: nowrap;
    }

    .about-intro :global(em)::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0.06em;
        height: 0.18em;
        background: var(--accent);
        opacity: 0.7;
        z-index: -1;
        border-radius: 9999px;
    }

    .about-prose {
        display: grid;
        gap: 1.25rem;
        font-size: 1rem;
        line-height: 1.8;
        color: var(--fg-muted);
    }

    @media (min-width: 640px) {
        .about-prose {
            font-size: 1.0625rem;
        }
    }
</style>
