---
import { about } from '../data/site';
---

<section id="about" class="scroll-mt-20 py-24 md:py-32 relative overflow-hidden">
    <div class="about-orb about-orb-a" aria-hidden="true"></div>
    <div class="about-orb about-orb-b" aria-hidden="true"></div>
    <div class="container-site relative z-10">
        <div class="grid items-start gap-12 md:grid-cols-12">
            <div class="md:col-span-5 md:sticky md:top-24">
                <span class="eyebrow reveal" data-reveal>{about.eyebrow}</span>
                <h2
                    class="display-section reveal mt-4 text-5xl sm:text-6xl lg:text-7xl"
                    data-reveal
                    data-reveal-delay="0.05"
                    set:html={about.title}
                />
                <div class="about-marquee mt-10 reveal" data-reveal data-reveal-delay="0.1">
                    <span>FULL-STACK</span>
                    <span>•</span>
                    <span>UI/UX</span>
                    <span>•</span>
                    <span>DEVOPS</span>
                    <span>•</span>
                    <span>PRODUCT THINKING</span>
                </div>
            </div>

            <div class="md:col-span-7 grid gap-6">
                <article class="about-card reveal" data-reveal data-reveal-delay="0.08">
                    <div class="about-image-stack">
                        <img src={about.images[0]} id="about_image_1" width="500" height="400" alt={about.eyebrow} class="about-main-image" loading="lazy" />
                        <img src={about.images[1]} id="about_image_2" width="260" height="210" alt="" class="about-float-image about-float-left" loading="lazy" />
                        <img src={about.images[2]} id="about_image_3" width="240" height="200" alt="" class="about-float-image about-float-right" loading="lazy" />
                    </div>
                </article>

                <article class="about-card rich reveal" data-reveal data-reveal-delay="0.12">
                    {about.paragraphs.map((p) => <p set:html={p} />)}
                </article>

                <article class="about-card rich reveal" data-reveal data-reveal-delay="0.16">
                    {about.bioParagraphs.map((p) => <p set:html={p} />)}
                </article>

                <div class="grid gap-3 sm:grid-cols-2">
                    {
                        about.strengths.map((item, index) => (
                            <div class="about-chip reveal" data-reveal data-reveal-delay={(0.2 + index * 0.03).toFixed(2)}>
                                <span class="about-chip-dot" aria-hidden="true"></span>
                                <span>{item}</span>
                            </div>
                        ))
                    }
                </div>

                <dl class="grid gap-3 md:grid-cols-2">
                    {
                        about.skills.map((s, index) => (
                            <div class="about-skill reveal" data-reveal data-reveal-delay={(0.22 + index * 0.03).toFixed(2)}>
                                <dt>{s.label}</dt>
                                <dd>{s.value}</dd>
                            </div>
                        ))
                    }
                </dl>
            </div>
        </div>
    </div>
</section>

<style>
    .about-orb {
        position: absolute;
        border-radius: 9999px;
        filter: blur(70px);
        opacity: 0.25;
        pointer-events: none;
    }

    .about-orb-a {
        width: 24rem;
        height: 24rem;
        top: 8rem;
        left: -10rem;
        background: color-mix(in srgb, var(--accent) 40%, transparent);
    }

    .about-orb-b {
        width: 28rem;
        height: 28rem;
        right: -12rem;
        bottom: 0;
        background: color-mix(in srgb, var(--fg) 22%, transparent);
    }

    .about-marquee {
        display: flex;
        flex-wrap: nowrap;
        overflow: hidden;
        white-space: nowrap;
        gap: 0.85rem;
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.16em;
        color: var(--fg-subtle);
    }

    .about-card {
        border: 1px solid var(--border);
        border-radius: 1.5rem;
        background: color-mix(in srgb, var(--surface) 84%, transparent);
        box-shadow: var(--shadow-md);
        padding: 1.25rem;
        backdrop-filter: blur(16px);
    }

    .about-image-stack {
        position: relative;
        min-height: 18rem;
    }

    .about-main-image {
        width: 100%;
        aspect-ratio: 16 / 10;
        border-radius: 1.2rem;
        object-fit: cover;
    }

    .about-float-image {
        position: absolute;
        width: clamp(7rem, 20vw, 10rem);
        aspect-ratio: 4 / 3;
        border-radius: 1rem;
        border: 1px solid var(--border);
        object-fit: cover;
        box-shadow: var(--shadow-sm);
    }

    .about-float-left {
        left: -0.25rem;
        bottom: -1.2rem;
        transform: rotate(-7deg);
    }

    .about-float-right {
        right: -0.25rem;
        top: -1rem;
        transform: rotate(8deg);
    }

    .about-chip {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        border-radius: 9999px;
        border: 1px solid var(--border);
        background: color-mix(in srgb, var(--surface) 82%, transparent);
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
        font-weight: 700;
    }

    .about-chip-dot {
        width: 0.45rem;
        height: 0.45rem;
        border-radius: 9999px;
        background: var(--accent);
    }

    .about-skill {
        border: 1px solid var(--border);
        border-radius: 1rem;
        background: color-mix(in srgb, var(--surface) 82%, transparent);
        padding: 1rem;
    }

    .about-skill dt {
        font-size: 0.68rem;
        letter-spacing: 0.18em;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--fg-subtle);
        margin-bottom: 0.35rem;
    }

    .about-skill dd {
        font-size: 0.85rem;
        font-weight: 600;
        line-height: 1.45;
        color: var(--fg-muted);
    }

    em {
        font-style: normal;
        position: relative;
        white-space: nowrap;
    }

    em::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0.06em;
        height: 0.18em;
        background: var(--accent);
        opacity: 0.8;
        z-index: -1;
        border-radius: 1rem;
    }
</style>
