---
import { hero } from '../data/site';
---

<section id="hero" class="hero-section scroll-mt-20 relative">
    <div class="hero-inner w-full">
        <div class="container-site grid gap-y-3 sm:gap-y-4" id="home_hero">
            <h1 class="hero-mobile-title sm:hidden">
                <span id="hero_title_1">Kaan</span>
                <br />
                <span id="hero_title_2">Tanış</span>
            </h1>
            <div class="grid grid-cols-2">
                <div class="self-center justify-self-start">
                    <h2 class="text-2xl sm:text-4xl md:text-6xl lg:text-7xl xl:text-8xl font-bold" id="designer">
                        {hero.title}
                    </h2>
                </div>
                <div>
                    <img
                        src={hero.image}
                        id="designer_image"
                        width="600"
                        height="300"
                        alt={`Kaan Tanış - ${hero.title}`}
                        class="aspect-[5/2] w-full rounded-full shadow object-cover"
                        fetchpriority="high"
                        loading="eager"
                    />
                </div>
            </div>
            <div class="grid grid-cols-2">
                <div>
                    <img
                        src={hero.image2}
                        id="developer_image"
                        width="600"
                        height="300"
                        alt={`Kaan Tanış - ${hero.title2}`}
                        class="aspect-[5/2] w-full rounded-full shadow object-cover"
                        loading="eager"
                    />
                </div>
                <div class="self-center justify-self-end">
                    <h2 class="text-2xl sm:text-4xl md:text-6xl lg:text-7xl xl:text-8xl font-bold" id="developer">
                        {hero.title2}
                    </h2>
                </div>
            </div>
        </div>

        <div class="container-site grid justify-end mt-8 sm:mt-24 relative z-20 hero-contact">
            <ul class="grid gap-y-2">
                <li>
                    <a
                        href={`https://github.com/${hero.github}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hero-link flex gap-x-2 text-xs items-center text-[var(--fg)]"
                    >
                        <svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.184 6.839 9.504.5.092.682-.217.682-.483 0-.237-.009-.868-.014-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.021C22 6.484 17.522 2 12 2z" />
                        </svg>
                        {hero.github}
                    </a>
                </li>
                <li>
                    <a
                        href={`https://wa.me/${hero.whatsappLink}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hero-link flex gap-x-2 text-xs items-center text-[var(--fg)]"
                    >
                        <svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" />
                        </svg>
                        {hero.whatsapp}
                    </a>
                </li>
                <li>
                    <a href={`mailto:${hero.email}`} class="hero-link flex gap-x-2 text-xs items-center text-[var(--fg)]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                        </svg>
                        {hero.email}
                    </a>
                </li>
            </ul>
        </div>

        <div class="container-site hero-scroll-cue">
            <a href="#about" id="hero_scroll_cue">
                <svg class="size-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
                <span class="sr-only">Aşağı kaydır</span>
            </a>
        </div>
    </div>
</section>

<style>
    .hero-section {
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: calc(100dvh - var(--site-header-offset));
        padding-top: calc(var(--site-header-offset) + 0.5rem);
        padding-bottom: max(5.5rem, env(safe-area-inset-bottom, 0px));
    }

    @media (min-width: 640px) {
        .hero-section {
            min-height: calc(100vh - 4.5rem);
            padding-top: 0;
            padding-bottom: 0;
        }
    }

    .hero-inner {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
    }

    .hero-mobile-title {
        position: relative;
        text-align: center;
        font-size: clamp(2.85rem, 13vw, 4.75rem);
        font-weight: 800;
        line-height: 0.95;
        letter-spacing: -0.03em;
        margin: 1rem 0 0.35rem;
        padding-top: 0.15rem;
    }

    .hero-mobile-title span {
        display: inline-block;
    }

    #hero_title_1 {
        margin-right: clamp(3.25rem, 22vw, 6rem);
    }

    #hero_title_2 {
        margin-left: clamp(3.25rem, 22vw, 6rem);
        opacity: 0.92;
    }

    .hero-scroll-cue {
        display: grid;
        justify-content: center;
        margin-top: 1.5rem;
        padding-bottom: 0.5rem;
    }

    @media (min-width: 640px) {
        .hero-scroll-cue {
            position: absolute;
            left: 0;
            right: 0;
            bottom: 1.25rem;
            margin-top: 0;
        }
    }

    .hero-contact {
        position: relative;
        z-index: 20;
    }
</style>
