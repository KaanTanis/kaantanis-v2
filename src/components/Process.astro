---
import { steps } from '../data/site';
---

<section id="process" class="slab-section scroll-mt-20">
    <header class="slab-prelude container-site">
        <span class="eyebrow reveal" data-reveal>SÜREÇ</span>
        <h2 class="display-section reveal mt-4 text-4xl sm:text-5xl md:text-6xl lg:text-7xl" data-reveal data-reveal-delay="0.05">
            Üç katman, <em>tek akış</em>.
        </h2>
        <p class="reveal mt-5 text-base font-medium text-[var(--fg-muted)] sm:text-lg" data-reveal data-reveal-delay="0.1">
            Editorial sertlik, sinematik geçiş. Her aşama bir <strong>sistem katmanı</strong>.
        </p>
    </header>

    <div class="slab-stack" data-slab-stack>
        {steps.map((step, index) => (
            <article class={`slab slab-${index + 1}`} data-step={index}>
                <div class="slab-stripe" aria-hidden="true">
                    <span>STAGE {step.n}</span>
                    <span class="slab-stripe-dot">/</span>
                    <span>{step.kicker.toUpperCase()}</span>
                    <span class="slab-stripe-fill"></span>
                    <span>0{index + 1} · 0{steps.length}</span>
                </div>

                <div class="slab-inner container-site">
                    <div class="slab-numeral-wrap" data-slab-numeral>
                        <span class="slab-numeral" aria-hidden="true">{step.n}</span>
                        <span class="slab-tag">{step.kicker}</span>
                    </div>

                    <div class="slab-body">
                        <div class="slab-image-frame" data-slab-frame>
                            <img
                                src={step.image}
                                alt={`Kaan Tanış - ${step.title}`}
                                loading="lazy"
                                decoding="async"
                                sizes="(max-width: 768px) 100vw, 50vw"
                            />
                            <span class="slab-frame-meta">FRAME {step.n}</span>
                            <span class="slab-frame-meta slab-frame-meta--right">REC ●</span>
                        </div>
                        <h3 class="slab-title">{step.title}</h3>
                        <div class="slab-text rich" set:html={step.content} />
                    </div>
                </div>
            </article>
        ))}
    </div>

    <nav class="slab-rail" aria-label="Süreç aşamaları" data-slab-rail>
        {steps.map((step, i) => (
            <button
                type="button"
                class="slab-rail-item"
                data-rail={i}
                aria-label={`${step.kicker}: ${step.title}`}
                aria-current="false"
            >
                <span class="slab-rail-num">{step.n}</span>
                <span class="slab-rail-label">{step.kicker}</span>
            </button>
        ))}
    </nav>
</section>

<style>
    .slab-section {
        position: relative;
        padding-top: 5rem;
    }

    .slab-prelude {
        max-width: 56rem;
        margin-inline: auto;
        text-align: center;
        padding-bottom: 3rem;
    }

    .slab-stack { position: relative; }

    .slab {
        position: relative;
        min-height: 92vh;
        display: flex;
        align-items: center;
        overflow: hidden;
        padding-block: 5rem;
        border-top: 1px solid var(--border);
    }

    .slab-1 { background: var(--bg); }
    .slab-2 {
        background:
            radial-gradient(circle at 80% 20%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 60%),
            var(--bg);
    }
    .slab-3 {
        background:
            radial-gradient(circle at 20% 80%, color-mix(in srgb, var(--fg) 10%, transparent), transparent 60%),
            var(--bg);
    }

    /* Editorial stripe along the top */
    .slab-stripe {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        padding: 0.65rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        color: var(--fg-subtle);
        text-transform: uppercase;
        border-bottom: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
        backdrop-filter: blur(10px);
        background: color-mix(in srgb, var(--bg) 70%, transparent);
    }
    .slab-stripe-dot { color: var(--fg-subtle); opacity: 0.5; }
    .slab-stripe-fill {
        flex: 1;
        height: 1px;
        background: repeating-linear-gradient(
            to right,
            color-mix(in srgb, var(--border-strong) 80%, transparent) 0 6px,
            transparent 6px 10px
        );
    }

    .slab-inner {
        display: grid;
        gap: 2.5rem;
        align-items: center;
        grid-template-columns: minmax(0, 0.45fr) minmax(0, 0.55fr);
    }

    .slab-numeral-wrap {
        position: relative;
        align-self: center;
    }
    .slab-numeral {
        display: block;
        font-size: clamp(7rem, 17vw, 22rem);
        font-weight: 800;
        line-height: 0.82;
        letter-spacing: -0.06em;
        color: transparent;
        -webkit-text-stroke: 2px var(--fg-strong);
    }
    .slab-2 .slab-numeral {
        color: var(--fg-strong);
        -webkit-text-stroke: 0;
    }
    .slab-3 .slab-numeral {
        color: transparent;
        -webkit-text-stroke: 2px var(--accent);
    }

    .slab-tag {
        display: inline-block;
        margin-top: 1rem;
        padding: 0.4rem 0.9rem;
        border: 1px solid var(--accent);
        border-radius: 9999px;
        background: color-mix(in srgb, var(--accent) 12%, transparent);
        color: var(--fg-strong);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
    }

    .slab-body { display: grid; gap: 1.2rem; }

    .slab-image-frame {
        position: relative;
        border: 1px solid var(--border);
        border-radius: 1rem;
        overflow: hidden;
        background: var(--surface);
        box-shadow: var(--shadow-md);
    }
    .slab-image-frame img {
        width: 100%;
        aspect-ratio: 16 / 10;
        object-fit: cover;
        display: block;
    }
    .slab-frame-meta {
        position: absolute;
        top: 0.7rem;
        left: 0.7rem;
        padding: 0.3rem 0.6rem;
        background: color-mix(in srgb, var(--bg) 88%, transparent);
        border: 1px solid var(--border);
        border-radius: 9999px;
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        color: var(--fg-muted);
        backdrop-filter: blur(8px);
    }
    .slab-frame-meta--right {
        left: auto;
        right: 0.7rem;
        color: var(--accent);
        border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    }

    .slab-title {
        font-size: clamp(1.75rem, 3.2vw, 2.8rem);
        line-height: 1.02;
        letter-spacing: -0.02em;
        font-weight: 800;
        margin: 0;
    }
    .slab-text {
        font-size: 1rem;
        line-height: 1.75;
        color: var(--fg-muted);
    }
    .slab-text :global(strong) {
        color: var(--fg-strong);
        font-weight: 800;
    }

    /* Floating rail */
    .slab-rail {
        position: fixed;
        top: 50%;
        right: 1rem;
        transform: translateY(-50%);
        display: grid;
        gap: 0.5rem;
        z-index: 30;
        pointer-events: auto;
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    .slab-section[data-rail-visible='true'] .slab-rail {
        opacity: 1;
    }
    .slab-rail-item {
        appearance: none;
        background: color-mix(in srgb, var(--bg) 80%, transparent);
        border: 1px solid var(--border);
        border-radius: 9999px;
        padding: 0.35rem 0.7rem;
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        color: var(--fg-muted);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        backdrop-filter: blur(10px);
        transition: all 0.25s ease;
    }
    .slab-rail-item:hover {
        color: var(--fg);
        border-color: var(--border-strong);
    }
    .slab-rail-item.is-active {
        background: var(--accent);
        color: var(--accent-fg);
        border-color: var(--accent);
    }
    .slab-rail-num { font-variant-numeric: tabular-nums; }
    .slab-rail-label { text-transform: uppercase; }

    @media (max-width: 980px) {
        .slab { min-height: auto; padding-block: 3.5rem; }
        .slab-inner { grid-template-columns: minmax(0, 1fr); gap: 1.5rem; }
        .slab-rail { display: none; }
        .slab-stripe { font-size: 0.6rem; padding: 0.5rem 1rem; gap: 0.5rem; }
        .slab-numeral { font-size: clamp(6rem, 28vw, 12rem); }
    }

    /* em underline (scoped) */
    .slab-prelude em {
        font-style: normal;
        position: relative;
        white-space: nowrap;
    }
    .slab-prelude em::after {
        content: '';
        position: absolute;
        left: 0; right: 0;
        bottom: 0.06em;
        height: 0.18em;
        background: var(--accent);
        opacity: 0.7;
        z-index: -1;
        border-radius: 9999px;
    }
</style>
