---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
    title?: string;
    description?: string;
}

const title = Astro.props.title ?? site.title;
const description = Astro.props.description ?? site.description;
const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImage = new URL(site.ogImage, site.url).href;

const jsonLd = {
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'WebSite',
            '@id': `${site.url}/#website`,
            url: site.url,
            name: site.title,
            headline: site.title,
            description: site.description,
            inLanguage: 'tr-TR',
            publisher: { '@id': `${site.url}/#organization` },
        },
        {
            '@type': 'Organization',
            '@id': `${site.url}/#organization`,
            name: site.name,
            url: site.url,
            logo: {
                '@type': 'ImageObject',
                url: `${site.url}/logo.svg`,
                width: 300,
                height: 300,
            },
        },
        {
            '@type': 'Person',
            '@id': `${site.url}/#person`,
            name: site.name,
            url: site.url,
            jobTitle: 'Software Developer & UI Designer',
            description: site.description,
            sameAs: site.sameAs,
            image: ogImage,
            worksFor: { '@id': `${site.url}/#organization` },
        },
        {
            '@type': 'WebPage',
            '@id': `${site.url}/#webpage`,
            url: site.url,
            name: site.title,
            description: site.description,
            isPartOf: { '@id': `${site.url}/#website` },
            about: { '@id': `${site.url}/#person` },
            inLanguage: 'tr-TR',
        },
    ],
};
---

<!doctype html>
<html lang="tr" data-theme="light">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />

        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="author" content={site.name} />
        <meta name="robots" content="index, follow, max-image-preview:large" />
        <link rel="canonical" href={canonical} />
        <meta name="google-site-verification" content={site.googleSiteVerification} />

        <meta property="og:type" content="website" />
        <meta property="og:locale" content={site.locale} />
        <meta property="og:site_name" content={site.name} />
        <meta property="og:url" content={canonical} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={`${site.name} — Software Developer & UI Designer`} />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content={site.twitter} />
        <meta name="twitter:creator" content={site.twitter} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />

        <link rel="icon" href="/logo.svg" type="image/svg+xml" />
        <link rel="preload" as="image" href="/assets/img/designer-w400.webp" media="(max-width: 640px)" fetchpriority="high" />
        <link rel="preload" as="image" href="/assets/img/designer-w800.webp" media="(min-width: 641px)" fetchpriority="high" />
        <link rel="preload" as="font" type="font/woff2" href="/fonts/gilroy/Gilroy-Medium.woff2" crossorigin />
        <link rel="preload" as="font" type="font/woff2" href="/fonts/gilroy/Gilroy-ExtraBold.woff2" crossorigin />

        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

        <script is:inline>
            (function () {
                var STATE_KEY = 'kaan-visit-state';
                var LEGACY_VISITS_KEY = 'kaan-visits';
                var THEME_KEY = 'theme';
                var SESSION_FLAG = 'kaan-session-counted';
                var WINDOW_MS = 86400000;
                var now = Date.now();

                function loadState() {
                    var state = {
                        visits: [],
                        surpriseShown: false,
                        userPickedTheme: false,
                        pendingSurprise: false,
                    };
                    try {
                        var raw = localStorage.getItem(STATE_KEY);
                        if (raw) {
                            var parsed = JSON.parse(raw);
                            if (parsed && Array.isArray(parsed.visits)) state = parsed;
                        } else {
                            var legacy = localStorage.getItem(LEGACY_VISITS_KEY);
                            if (legacy) state.visits = JSON.parse(legacy);
                        }
                    } catch (e) {}
                    if (localStorage.getItem('kaan-surprise-shown') === '1') state.surpriseShown = true;
                    if (localStorage.getItem('kaan-theme-user-picked') === '1') state.userPickedTheme = true;
                    state.visits = (state.visits || []).filter(function (t) {
                        return now - t < WINDOW_MS;
                    });
                    return state;
                }

                function saveState(state) {
                    try {
                        localStorage.setItem(STATE_KEY, JSON.stringify(state));
                        localStorage.removeItem(LEGACY_VISITS_KEY);
                    } catch (e) {}
                }

                var state = loadState();
                var newSession = !sessionStorage.getItem(SESSION_FLAG);

                if (newSession) {
                    sessionStorage.setItem(SESSION_FLAG, '1');
                    state.visits.push(now);
                }

                var visitCount = state.visits.length;
                var theme = 'light';
                var stored = localStorage.getItem(THEME_KEY);

                if (state.userPickedTheme && (stored === 'light' || stored === 'dark' || stored === 'cyberpunk')) {
                    theme = stored;
                    state.pendingSurprise = false;
                } else if (visitCount === 2 && !state.surpriseShown) {
                    theme = 'cyberpunk';
                    state.pendingSurprise = true;
                    try {
                        localStorage.setItem(THEME_KEY, 'cyberpunk');
                    } catch (e) {}
                } else if (visitCount >= 3) {
                    theme = stored === 'dark' ? 'dark' : 'light';
                    state.pendingSurprise = false;
                    if (stored === 'cyberpunk') {
                        theme = 'light';
                        try {
                            localStorage.setItem(THEME_KEY, 'light');
                        } catch (e) {}
                    }
                } else {
                    theme = stored === 'dark' ? 'dark' : 'light';
                    state.pendingSurprise = false;
                    if (!stored) {
                        try {
                            localStorage.setItem(THEME_KEY, 'light');
                        } catch (e) {}
                    }
                }

                saveState(state);
                document.documentElement.setAttribute('data-theme', theme);
            })();
        </script>
    </head>
    <body class="overflow-x-hidden antialiased">
        <slot />
        <script>
            import { scheduleAnalytics } from '../scripts/analytics.ts';
            scheduleAnalytics();
        </script>
    </body>

</html>
