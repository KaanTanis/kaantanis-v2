# =============================================================================
# kaantanis.com — ortam değişkenleri
# =============================================================================
# Kurulum:  cp .env.example .env
# PM2:       ecosystem.config.cjs → env_file: '.env' (tek kaynak)
# Nginx:     proxy_pass http://127.0.0.1:${PORT};
# =============================================================================

# --- Sunucu (Astro Node adapter / PM2) ---------------------------------------
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# --- Telegram — iletişim formu bildirimi (opsiyonel) -------------------------
# Boş bırakılırsa POST /api/contact yine 200 döner; Telegram’a mesaj gitmez.
# Bot: https://t.me/BotFather  |  Chat ID: getUpdates ile alınır
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# Geliştirme (lokal npm run dev) — üretimde değiştirmeyin
# =============================================================================
# NODE_ENV=development
# PORT=4321
